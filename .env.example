# SubManager Configuration
# 复制此文件为 .env 并修改配置

# 外部访问端口
HTTP_PORT=80
HTTPS_PORT=443

# JWT 密钥 (生产环境请使用 openssl rand -hex 32 生成)
APP_SECRET=change_me_in_production

# 管理员初始化令牌 (一次性使用，生产环境请使用 openssl rand -hex 16 生成)
INIT_TOKEN=change_me_init_token

# 数据库配置
DB_NAME=submanager
DB_USER=submgr
DB_PASSWORD=change_me_db_password

# 订阅基础 URL (用户获取订阅链接时使用，必须可公网访问)
SUB_BASE_URL=http://localhost

# 管理员账户
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_admin_password

# 用户注册开关
ALLOW_REGISTER=true

# Agent 配置
AGENT_REPORT_INTERVAL=60
AGENT_OFFLINE_TIMEOUT=180

# 订阅源自动刷新间隔(分钟)
SUB_REFRESH_INTERVAL=30

# SSL 证书路径 (留空则仅 HTTP，去掉前面的 # 启用)
# SSL_CERT_PATH=./nginx/ssl/cert.pem
# SSL_KEY_PATH=./nginx/ssl/key.pem